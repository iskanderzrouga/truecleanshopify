        "list_zTaACM": {
          "type": "list",
          "settings": {
            "image": "shopify://shop_images/Rectangle_240648346_2.png",
            "heading": "3. It Works Automatically With Every Flush",
            "text": "<p>Clip it to your overflow tube. Walk away. Done in 60 seconds  — no tools, no plumber, no complicated installation.<br/><br/>Every flush releases a precise dose of cleaning solution directly into your bowl. You don't have to remember anything. You don't have to do anything.<br/><br/>Your toilet cleans itself while you sleep, while you're at work, while you're living your life.</p>",
            "star_text1": "",
