{% if section.settings.product != blank %}
  {% assign product = section.settings.product %}
{% endif %}

<section
  id="{{ section.settings.anchor_id | default: 'pricing' }}"
  class="section-{{ section.id }}-padding"
  data-tc-pricing="{{ section.id }}"
  data-toilets-option="{{ section.settings.toilets_option_name | default: '' }}"
  data-duration-option="{{ section.settings.duration_option_name | default: '' }}"
>
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_m }}px;
      padding-bottom: {{ section.settings.padding_bottom_m }}px;
      background: #f4f4f6;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    .section-{{ section.id }}-padding .tc-pricing-selector {
      border: 1px solid #d9dde0;
      background-color: #fafafa;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    .section-{{ section.id }}-padding .tc-pricing-selector.is-active {
      border-color: #00b7a2;
      background-color: #f5fffe;
      box-shadow: 0 0 0 1px #00b7a2 inset;
    }

    .section-{{ section.id }}-padding .tc-pricing-selector:focus-visible {
      outline: 2px solid #00b7a2;
      outline-offset: 2px;
    }

    .section-{{ section.id }}-padding .tc-pricing-selector[aria-pressed='true'] {
      border-color: #00b7a2;
      background-color: #f5fffe;
    }
  {%- endstyle -%}

  <div class="mx-auto w-full relative px-4 md:px-0" style="max-width: {{ section.settings.max_width }}px;">
    {% if section.settings.show_shipping_banner %}
      <div class="max-md:px-0">
        <div class="flex justify-center gap-2 py-3 px-4 mb-6 rounded-lg border-[#000000] border bg-[#E8FF33]">
          <span class="min-w-[20px]">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M11.0822 2.62305L18.2772 15.0847C18.3869 15.2747 18.4446 15.4903 18.4446 15.7097C18.4446 15.9291 18.3869 16.1447 18.2772 16.3347C18.1675 16.5247 18.0097 16.6825 17.8196 16.7922C17.6296 16.9019 17.4141 16.9597 17.1947 16.9597H2.80466C2.58524 16.9597 2.36969 16.9019 2.17967 16.7922C1.98965 16.6825 1.83185 16.5247 1.72215 16.3347C1.61244 16.1447 1.55469 15.9291 1.55469 15.7097C1.55469 15.4903 1.61245 15.2747 1.72216 15.0847L8.91716 2.62305C9.39799 1.78971 10.6005 1.78971 11.0822 2.62305ZM9.99966 12.4997C9.77864 12.4997 9.56668 12.5875 9.4104 12.7438C9.25412 12.9001 9.16632 13.112 9.16632 13.333C9.16632 13.5541 9.25412 13.766 9.4104 13.9223C9.56668 14.0786 9.77864 14.1664 9.99966 14.1664C10.2207 14.1664 10.4326 14.0786 10.5889 13.9223C10.7452 13.766 10.833 13.5541 10.833 13.333C10.833 13.112 10.7452 12.9001 10.5889 12.7438C10.4326 12.5875 10.2207 12.4997 9.99966 12.4997ZM9.99966 6.66638C9.79554 6.66641 9.59854 6.74134 9.44601 6.87698C9.29348 7.01261 9.19604 7.1995 9.17216 7.40221L9.16632 7.49971V10.833C9.16656 11.0454 9.24789 11.2497 9.3937 11.4042C9.5395 11.5586 9.73878 11.6516 9.95082 11.664C10.1629 11.6765 10.3716 11.6075 10.5345 11.4712C10.6974 11.3348 10.8021 11.1415 10.8272 10.9305L10.833 10.833V7.49971C10.833 7.2787 10.7452 7.06674 10.5889 6.91046C10.4326 6.75418 10.2207 6.66638 9.99966 6.66638Z" fill="black"/>
            </svg>
          </span>
          {% assign target_date = '2026-01-20' | date: '%s' %}
          {% assign today_date = 'now' | date: '%s' %}
          {% assign diff_seconds = target_date | minus: today_date %}
          {% assign diff_days = diff_seconds | divided_by: 86400 %}

          {% assign today = 'now' | date: '%-d %b' | upcase %}
          <p class="text-[13px] md:text-[18px] font-medium text-[#000000] !leading-tight">
            <span class="underline font-bold">Urgent Update: {{ today }}</span>, {{ section.settings.shipping_heading | replace: 'DATEPLACEHOLDER', diff_days }}
          </p>
        </div>
      </div>
    {% endif %}

    {% if section.settings.show_urgency_banner %}
      <div class="text-center py-3 px-4 mb-6 rounded-lg" style="background-color: #D30101 !important; color: #ffffff !important;">
        <p class="text-[18px] md:text-[22px] font-bold m-0 mb-1" style="color: #ffffff !important;">
          {{ section.settings.urgency_heading }}
        </p>
        <p class="text-[14px] md:text-[16px] m-0" style="color: rgba(255,255,255,0.9) !important;">
          {{ section.settings.urgency_subheading }}
        </p>
      </div>
    {% endif %}

    <div class="text-center mb-10">
      {% if section.settings.heading != blank %}
        <h2 class="text-[26px] md:text-[34px] font-bold text-[#001C19] mb-3" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="text-[18px] md:text-[20px] font-medium text-[#001C19]">
          {{ section.settings.description }}
        </div>
      {% endif %}
    </div>

    <div class="bg-white rounded-[24px] shadow-md p-5 md:p-8">
      <div class="mb-6">
        <label class="block text-[18px] md:text-[20px] font-bold text-[#001C19] mb-4">
          Step 1: How many toilets?
        </label>
        <div class="grid grid-cols-4 gap-3">
          {% for count in (1..4) %}
            <button
              type="button"
              class="tc-pricing-selector tc-toilet-btn rounded-[14px] py-4 px-2 text-center font-semibold text-[#001C19]"
              data-toilets="{{ count }}"
              aria-pressed="false"
            >
              <div class="text-[30px] md:text-[34px] mb-1">{% for i in (1..count) %}🚽{% endfor %}</div>
              <div class="text-[15px] md:text-[16px]">{{ count }}</div>
            </button>
          {% endfor %}
        </div>
      </div>

      <div class="mb-6">
        <label class="block text-[18px] md:text-[20px] font-bold text-[#001C19] mb-4" data-step-two-label>
          Step 2: How long?
        </label>
        <div class="grid grid-cols-4 gap-3">
          {% assign duration_labels = 'Try it,Popular,Save 15%,Best Value' | split: ',' %}
          {% assign duration_values = '3,6,12,24' | split: ',' %}
          {% for duration in duration_values %}
            {% assign index = forloop.index0 %}
            {% assign badge = duration_labels[index] %}
            <button
              type="button"
              class="tc-pricing-selector tc-duration-btn rounded-[14px] py-4 px-2 text-center font-semibold text-[#001C19]"
              data-months="{{ duration }}"
              aria-pressed="false"
            >
              <div class="text-[12px] text-[#666]">{{ badge }}</div>
              <div class="text-[16px] md:text-[17px]">
                {% if duration == '12' %}
                  1 year
                {% elsif duration == '24' %}
                  2 years
                {% else %}
                  {{ duration }} mo
                {% endif %}
              </div>
            </button>
          {% endfor %}
        </div>
      </div>

      <div class="bg-[#F5FFFE] rounded-[18px] p-5 md:p-6 mb-6 border border-[#DFF4F4]">
        <div class="text-center mb-6 pb-6 border-b border-[#DFF4F4]">
          <div class="text-[#666] mb-2 text-[16px] md:text-[18px]">Your order:</div>
          <div class="text-[24px] md:text-[28px] font-bold text-[#001C19]" id="order-summary-{{ section.id }}"></div>
          <div class="text-[#00B7A2] font-semibold mt-2 text-[17px] md:text-[19px]" id="includes-text-{{ section.id }}"></div>
        </div>

        <div class="text-center">
          <div class="flex items-center justify-center gap-3">
            <span class="text-[26px] md:text-[30px] font-black text-[#001C19]" id="price-each-{{ section.id }}"></span>
            <span class="text-[#999] line-through text-[13px] md:text-[14px]" id="original-price-{{ section.id }}"></span>
          </div>
          <div class="text-[#00B67A] font-semibold mt-1" id="savings-percent-{{ section.id }}"></div>
          <div class="text-[#666] text-[13px] md:text-[14px] mt-1" id="per-month-{{ section.id }}"></div>
        </div>
      </div>

      <div class="bg-[#001C19] rounded-[18px] p-5 md:p-6">
        <div class="flex items-center justify-between mb-4">
          <div class="text-white">
            <div class="text-[12px] text-[#9CA3AF]">Order Total:</div>
            <div class="text-[26px] md:text-[30px] font-black" id="final-price-{{ section.id }}"></div>
          </div>
          <div class="text-right text-white">
            <div class="text-[#A7F3D0] font-semibold" id="savings-text-{{ section.id }}"></div>
            <div class="text-[#9CA3AF] text-[12px]">Free shipping included</div>
          </div>
        </div>
        <form method="post" action="/cart/add" class="tc-pricing-form">
          <input type="hidden" name="id" id="variant-id-{{ section.id }}" value="">
          <button
            type="submit"
            class="w-full bg-[#00B7A2] hover:bg-[#00A190] text-white font-bold text-[18px] py-4 rounded-[12px] transition"
            id="add-to-cart-{{ section.id }}"
          >
            Add To Cart →
          </button>
        </form>
      </div>

      <div class="flex flex-wrap justify-center gap-4 mt-6 text-[12px] text-[#6B7280]">
        <span>🔒 Secure Checkout</span>
        <span>🚚 Free Shipping</span>
        <span>↩️ 90-Day Guarantee</span>
      </div>
    </div>
  </div>

  <script type="application/json" data-variants>
    {{ product.variants | json }}
  </script>
  <script type="application/json" data-options>
    {{ product.options | json }}
  </script>
  {% capture variant_map_items %}
    {% assign first_map = true %}
    {% for block in section.blocks %}
      {% if block.type == 'variant_map' %}
        {% unless first_map %},{% endunless %}
        {"toilets":{{ block.settings.toilets | default: 0 }},"months":{{ block.settings.months | default: 0 }},"variant_id":{{ block.settings.variant_id | default: 0 }}}
        {% assign first_map = false %}
      {% endif %}
    {% endfor %}
  {% endcapture %}
  <script type="application/json" data-variant-maps>
    [{{ variant_map_items | strip }}]
  </script>

  <script>
    (() => {
      const section = document.querySelector('[data-tc-pricing="{{ section.id }}"]');
      if (!section) return;

      const toiletButtons = Array.from(section.querySelectorAll('[data-toilets]'));
      const durationButtons = Array.from(section.querySelectorAll('[data-months]'));
      const stepTwoLabel = section.querySelector('[data-step-two-label]');
      const orderSummary = section.querySelector('#order-summary-{{ section.id }}');
      const includesText = section.querySelector('#includes-text-{{ section.id }}');
      const originalPriceEl = section.querySelector('#original-price-{{ section.id }}');
      const priceEachEl = section.querySelector('#price-each-{{ section.id }}');
      const savingsPercentEl = section.querySelector('#savings-percent-{{ section.id }}');
      const perMonthEl = section.querySelector('#per-month-{{ section.id }}');
      const finalPriceEl = section.querySelector('#final-price-{{ section.id }}');
      const savingsTextEl = section.querySelector('#savings-text-{{ section.id }}');
      const variantInput = section.querySelector('#variant-id-{{ section.id }}');
      const addToCartButton = section.querySelector('#add-to-cart-{{ section.id }}');

      const variants = JSON.parse(section.querySelector('[data-variants]').textContent || '[]') || [];
      const options = JSON.parse(section.querySelector('[data-options]').textContent || '[]') || [];
      const variantMaps = JSON.parse(section.querySelector('[data-variant-maps]').textContent || '[]') || [];

      const moneyFormat = {{ shop.money_format | json }};
      const currencyCode = {{ cart.currency.iso_code | default: shop.currency | json }};

      const formatMoney = (cents) => {
        if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
          return window.Shopify.formatMoney(cents, moneyFormat);
        }
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: currencyCode
        }).format((cents || 0) / 100);
      };

      const extractNumber = (value) => {
        if (!value) return null;
        const match = String(value).match(/\d+/);
        return match ? parseInt(match[0], 10) : null;
      };

      const findVariant = (toilets, months) => {
        const mapMatch = variantMaps.find((map) => Number(map.toilets) === toilets && Number(map.months) === months && Number(map.variant_id) > 0);
        if (mapMatch) {
          return variants.find((variant) => Number(variant.id) === Number(mapMatch.variant_id));
        }

        const toiletsOptionName = section.dataset.toiletsOption;
        const durationOptionName = section.dataset.durationOption;
        const toiletsIndex = toiletsOptionName ? options.indexOf(toiletsOptionName) : -1;
        const durationIndex = durationOptionName ? options.indexOf(durationOptionName) : -1;

        const matches = variants.filter((variant) => {
          const variantOptions = variant.options || [];
          const optionToilets = toiletsIndex >= 0 ? variantOptions[toiletsIndex] : variantOptions.find((opt) => extractNumber(opt) === toilets);
          const optionDuration = durationIndex >= 0 ? variantOptions[durationIndex] : variantOptions.find((opt) => extractNumber(opt) === months);
          return extractNumber(optionToilets) === toilets && extractNumber(optionDuration) === months;
        });

        return matches.find((variant) => variant.available) || matches[0] || null;
      };

      let selectedToilets = 2;
      let selectedDuration = 6;

      const setActive = (buttons, value, dataAttr) => {
        buttons.forEach((button) => {
          const isActive = Number(button.dataset[dataAttr]) === value;
          button.classList.toggle('is-active', isActive);
          button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      };

      const getDefaultValue = (buttons, preferred) => {
        if (buttons.some((button) => Number(button.dataset[preferred.key]) === preferred.value)) {
          return preferred.value;
        }
        const first = buttons[0];
        return first ? Number(first.dataset[preferred.key]) : preferred.value;
      };

      const updateStepLabel = () => {
        if (!stepTwoLabel) return;
        stepTwoLabel.textContent = selectedToilets > 1 ? 'Step 2: How long for each?' : 'Step 2: How long?';
      };

      const durationLabel = (months) => `${months} month${months === 1 ? '' : 's'}`;

      const updateSummary = () => {
        const toiletLabel = selectedToilets === 1 ? 'toilet' : 'toilets';
        orderSummary.textContent = `${selectedToilets} ${toiletLabel} × ${durationLabel(selectedDuration)} of cleaning`;

        const cartridgesPerToilet = Math.max(1, Math.round(selectedDuration / 3));
        const dispensers = selectedToilets;
        const cartridges = selectedToilets * cartridgesPerToilet;
        includesText.textContent = `Includes ${dispensers} FREE dispenser${dispensers === 1 ? '' : 's'} + ${cartridges} cleaning cartridge${cartridges === 1 ? '' : 's'}`;
      };

      const updatePricing = () => {
        const variant = findVariant(selectedToilets, selectedDuration);
        if (!variant) {
          originalPriceEl.textContent = '';
          priceEachEl.textContent = '—';
          savingsPercentEl.textContent = '';
          perMonthEl.textContent = '';
          finalPriceEl.textContent = '—';
          savingsTextEl.textContent = '';
          variantInput.value = '';
          addToCartButton.disabled = true;
          addToCartButton.classList.add('opacity-50');
          return;
        }

        const price = Number(variant.price || 0);
        const compareAt = Number(variant.compare_at_price || 0);
        const hasSavings = compareAt > price;

        priceEachEl.textContent = formatMoney(price);
        finalPriceEl.textContent = formatMoney(price);

        if (hasSavings) {
          originalPriceEl.textContent = formatMoney(compareAt);
          const savings = compareAt - price;
          const savingsPercent = Math.round((savings / compareAt) * 100);
          savingsPercentEl.textContent = `Save ${savingsPercent}%`;
          savingsTextEl.textContent = `You save ${formatMoney(savings)}!`;
        } else {
          originalPriceEl.textContent = '';
          savingsPercentEl.textContent = '';
          savingsTextEl.textContent = '';
        }

        const perMonthCents = selectedDuration ? Math.round(price / selectedDuration) : price;
        perMonthEl.textContent = `Just ${formatMoney(perMonthCents)}/month`;

        variantInput.value = variant.id;
        addToCartButton.disabled = !variant.available;
        addToCartButton.classList.toggle('opacity-50', !variant.available);
      };

      const initialize = () => {
        selectedToilets = getDefaultValue(toiletButtons, { key: 'toilets', value: selectedToilets });
        selectedDuration = getDefaultValue(durationButtons, { key: 'months', value: selectedDuration });

        setActive(toiletButtons, selectedToilets, 'toilets');
        setActive(durationButtons, selectedDuration, 'months');

        updateStepLabel();
        updateSummary();
        updatePricing();
      };

      toiletButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectedToilets = Number(button.dataset.toilets);
          setActive(toiletButtons, selectedToilets, 'toilets');
          updateStepLabel();
          updateSummary();
          updatePricing();
        });
      });

      durationButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectedDuration = Number(button.dataset.months);
          setActive(durationButtons, selectedDuration, 'months');
          updateSummary();
          updatePricing();
        });
      });

      initialize();
    })();
  </script>
</section>

{% schema %}
{
  "name": "TC Pricing Calculator",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "default": "pricing"
    },
    {
      "type": "text",
      "id": "toilets_option_name",
      "label": "Toilets Option Name",
      "default": "Bathrooms"
    },
    {
      "type": "text",
      "id": "duration_option_name",
      "label": "Duration Option Name",
      "default": "Duration"
    },
    {
      "type": "header",
      "content": "Urgency Banner"
    },
    {
      "type": "checkbox",
      "id": "show_shipping_banner",
      "label": "Show Urgency Banner",
      "default": true
    },
    {
      "type": "html",
      "id": "shipping_heading",
      "label": "Shipping Heading",
      "default": ", Orders will ship in 2 weeks due to high demand"
    },
    {
      "type": "checkbox",
      "id": "show_urgency_banner",
      "label": "Show Urgency Banner",
      "default": true
    },
    {
      "type": "text",
      "id": "urgency_heading",
      "label": "Urgency Heading",
      "default": "GET UP TO 50% OFF WITH YOUR ORDER TODAY!"
    },
    {
      "type": "text",
      "id": "urgency_subheading",
      "label": "Urgency Subheading",
      "default": "Hurry! This special offer is only available while supplies last!"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Much Scrub-Free Time Do You Want?"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Pick your toilets. Pick your duration. Everything you need is included.</p>"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#001C19"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 800,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "label": "Max Width",
      "default": 1280
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_top_m",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom_m",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "variant_map",
      "name": "Variant Map",
      "settings": [
        {
          "type": "select",
          "id": "toilets",
          "label": "Toilets",
          "options": [
            {"value": "1", "label": "1"},
            {"value": "2", "label": "2"},
            {"value": "3", "label": "3"},
            {"value": "4", "label": "4"}
          ],
          "default": "1"
        },
        {
          "type": "select",
          "id": "months",
          "label": "Months",
          "options": [
            {"value": "3", "label": "3"},
            {"value": "6", "label": "6"},
            {"value": "12", "label": "12"},
            {"value": "24", "label": "24"}
          ],
          "default": "3"
        },
        {
          "type": "text",
          "id": "variant_id",
          "label": "Variant ID"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "TC Pricing Calculator"
    }
  ]
}
{% endschema %}
