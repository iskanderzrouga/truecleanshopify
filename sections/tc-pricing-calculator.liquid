      "name": "TC Pricing Calculator",
      "blocks": [
        {"type": "variant_map", "settings": {"toilets": "1", "months": "3", "variant_id": "0"}},
        {"type": "variant_map", "settings": {"toilets": "1", "months": "6", "variant_id": "0"}},
        {"type": "variant_map", "settings": {"toilets": "1", "months": "12", "variant_id": "0"}},
        {"type": "variant_map", "settings": {"toilets": "1", "months": "24", "variant_id": "0"}},
        {"type": "variant_map", "settings": {"toilets": "2", "months": "3", "variant_id": "0"}},
        {"type": "variant_map", "settings": {"toilets": "2", "months": "6", "variant_id": "0"}},
        {"type": "variant_map", "settings": {"toilets": "2", "months": "12", "variant_id": "0"}},
