{% comment %} <div class="max-md:w-[175px] max-md:max-w-[175px] max-md:min-w-[175px] max-md:pr-[10px]">
                    {{
                      block.settings.image
                      | image_url: width: 165
                      | image_tag:
                        class: 'max-md:w-[165px] max-md:max-w-[165px] max-md:min-w-[165px] max-md:object-contain max-md:rounded-[20px]',
                        sizes: '165px',
                        preload: true
                    }}
                  </div> {% endcomment %}

<div class="max-md:w-[175px] max-md:max-w-[175px] max-md:min-w-[175px] max-md:pr-[10px] md:h-[340px] md:max-h-[340px] md:min-h-[340px] md:pb-5">
                    {{
                      block.settings.image
                      | image_url: width: 220
                      | image_tag:
                        class: 'max-md:w-[165px] max-md:max-w-[165px] max-md:min-w-[165px] max-md:object-contain max-md:rounded-[20px] md:h-[320px] md:max-h-[320px] md:min-h-[320px] md:object-cover md:rounded-[20px]',
                        sizes: '320px',
                        preload: true
                    }}
                  </div>